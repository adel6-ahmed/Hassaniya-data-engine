# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================
# Generate a secure secret key using:
# openssl rand -base64 32
# or node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=your-secret-key-here

# NextAuth.js configuration
# Set to your production domain in production
AUTH_URL=http://localhost:3000

# Optional: Google OAuth
AUTH_GOOGLE_ID=your-google-client-id-here
AUTH_GOOGLE_SECRET=your-google-client-secret-here

# Optional: GitHub OAuth
AUTH_GITHUB_ID=your-github-client-id-here
AUTH_GITHUB_SECRET=your-github-client-secret-here

# ============================================================================
# DATABASE - PostgreSQL via Supabase
# ============================================================================
# Your PostgreSQL connection string
# Format: postgresql://user:password@host:5432/database
DATABASE_URL=postgresql://user:password@localhost:5432/hassaniya_db

# Direct database URL (for Prisma migrations)
DIRECT_URL=postgresql://user:password@localhost:5432/hassaniya_db

# ============================================================================
# SUPABASE - Vector Search, Storage & Edge Functions
# ============================================================================
# Your Supabase project URL (public)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase Anon Key (public, safe to expose)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role Key (KEEP SECRET!)
# Only use this on the server-side
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================================================
# OPTIONAL: Content Security / Analytics
# ============================================================================
# NEXT_PUBLIC_ANALYTICS_ID=your-analytics-id
# LOG_LEVEL=info

# ============================================================================
# NOTES FOR PRODUCTION DEPLOYMENT
# ============================================================================
# 1. Never commit this file to Git - it will be in .gitignore
# 2. Set all variables in your hosting provider's environment settings
# 3. For AUTH_SECRET: Generate a new secure value, don't reuse dev values
# 4. For NODE_ENV: Hosting providers usually set this automatically
# 5. Test DATABASE_URL connectivity before deploying
# 6. Ensure all SUPABASE credentials are correct for your project
# 7. Use strong passwords/keys for production credentials
